PORT=4000
DATABASE_URL=postgres://postgres:postgres@localhost:5432/syncra
JWT_SECRET=replace_with_a_long_random_secret
ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_TTL_DAYS=30
JSON_BODY_LIMIT=1mb
AUTH_RATE_WINDOW_MS=600000
AUTH_RATE_MAX_REQUESTS=30
SYNC_RATE_WINDOW_MS=60000
SYNC_RATE_MAX_REQUESTS=120
SYNC_BODY_MAX_BYTES=262144
NOTES_ENABLED=true
NOTE_DOC_SCHEMA_VERSION=1
NOTE_CONTENT_MAX_BYTES=131072
TOMBSTONE_RETENTION_DAYS=30
REFRESH_TOKEN_CLEANUP_RETENTION_DAYS=30
SYNC_FAILURE_RETENTION_DAYS=30
AUDIT_LOG_RETENTION_DAYS=90
