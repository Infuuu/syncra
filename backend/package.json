{
  "name": "syncra-backend",
  "version": "0.1.0",
  "description": "Basic backend starter for Syncra",
  "main": "src/server.js",
  "type": "commonjs",
  "scripts": {
    "dev": "node src/server.js",
    "start": "node src/server.js",
    "db:migrate": "node src/db/migrate.js",
    "job:cleanup:tombstones": "node src/jobs/cleanupTombstones.js",
    "job:cleanup:maintenance": "node src/jobs/cleanupMaintenance.js",
    "test": "npm run db:migrate && node --test --test-concurrency=1 test/**/*.test.js"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.12.0",
    "supertest": "^7.1.4",
    "ws": "^8.18.0"
  }
}
